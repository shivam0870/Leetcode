class Solution {
public:
    string finalString(string s) {
        string result;
          int n = s.length();
         for (int i = 0; i < n; ++i) {
            if (s[i] == 'i') {
             reverse(result.begin(), result.end());   
            }
             else {
              result += s[i];   
             }
         }
        return result;
    }
};
